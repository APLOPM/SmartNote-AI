// This schema is based on the Agent Memory Layer ERD
// File: prisma/schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// -------------------------------------------
// Core User Model
// -------------------------------------------
model User {
  id            String          @id @default(uuid())
  email         String          @unique
  planType      PlanType        @default(FREE)
  createdAt     DateTime        @default(now()) @map("created_at")
  agentSessions AgentSession[]
  longTermMemories LongTermMemory[]
  apiKeys       ApiKey[]

  @@map("users")
}

model ApiKey {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  workspaceId String    @map("workspace_id")
  keyHash     String    @unique @map("key_hash")
  keyPrefix   String    @map("key_prefix")
  scopes      String[]
  createdAt   DateTime  @default(now()) @map("created_at")
  lastUsedAt  DateTime? @map("last_used_at")
  expiresAt   DateTime? @map("expires_at")
  revokedAt   DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId, userId])
  @@index([workspaceId, revokedAt, expiresAt])
  @@map("api_keys")
}

enum PlanType {
  FREE
  PRO
  ENTERPRISE
}


// -------------------------------------------
// Agent Session & Conversation
// -------------------------------------------
model AgentSession {
  id                  String                @id @default(uuid())
  userId              String
  mode                AgentMode
  status              SessionStatus
  startedAt           DateTime              @default(now()) @map("started_at")
  expiresAt           DateTime              @map("expires_at")
  
  user                User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  agentTasks          AgentTask[]
  shortTermMemory     ShortTermMemory[]
  conversationMessages ConversationMessage[]

  @@index([userId])
  @@map("agent_sessions")
}

enum AgentMode {
  QUICK
  DEEP
  AUTONOMOUS
}

enum SessionStatus {
  ACTIVE
  CLOSED
}

model ConversationMessage {
  id          String        @id @default(uuid())
  sessionId   String
  role        MessageRole
  content     String
  tokenCount  Int           @map("token_count")
  createdAt   DateTime      @default(now()) @map("created_at")

  session     AgentSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("conversation_messages")
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}


// -------------------------------------------
// Agent Task & Workflow State
// -------------------------------------------
model AgentTask {
  id                String          @id @default(uuid())
  sessionId         String
  goal              String
  status            TaskStatus
  currentStepIndex  Int             @default(0) @map("current_step_index")
  totalSteps        Int             @default(0) @map("total_steps")
  modelUsed         String?         @map("model_used")
  costEstimate      Decimal?        @map("cost_estimate")
  createdAt         DateTime        @default(now()) @map("created_at")
  completedAt       DateTime?       @map("completed_at")

  session           AgentSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  steps             TaskStep[]
  toolExecutions    ToolExecution[]
  snapshots         TaskSnapshot[]
  eventLogs         TaskEventLog[]
  memoryLinks       LongTermMemoryLink[]

  @@index([sessionId, status])
  @@map("agent_tasks")
}

enum TaskStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  PAUSED
}

model TaskStep {
  id            String        @id @default(uuid())
  taskId        String
  stepIndex     Int           @map("step_index")
  actionName    String        @map("action_name")
  inputPayload  Json?         @map("input_payload")
  outputPayload Json?         @map("output_payload")
  status        StepStatus
  startedAt     DateTime?     @map("started_at")
  finishedAt    DateTime?     @map("finished_at")

  task          AgentTask     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  toolExecutions ToolExecution[]

  @@unique([taskId, stepIndex])
  @@map("task_steps")
}

enum StepStatus {
  PENDING
  SUCCESS
  FAILED
}

model ToolExecution {
  id          String    @id @default(uuid())
  taskId      String
  stepId      String?   // Can be null if it's a pre/post step tool
  toolName    String    @map("tool_name")
  parameters  Json
  result      Json?
  success     Boolean
  latencyMs   Int       @map("latency_ms")
  retryCount  Int       @default(0) @map("retry_count")
  createdAt   DateTime  @default(now()) @map("created_at")

  task        AgentTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  step        TaskStep? @relation(fields: [stepId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([stepId])
  @@map("tool_executions")
}

model TaskSnapshot {
  id            String    @id @default(uuid())
  taskId        String
  snapshotData  Json      @map("snapshot_data")
  createdAt     DateTime  @default(now()) @map("created_at")

  task          AgentTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  @@index([taskId])
  @@map("task_snapshots")
}

model TaskEventLog {
  id          String    @id @default(uuid())
  taskId      String
  eventType   String    @map("event_type")
  metadata    Json?
  createdAt   DateTime  @default(now()) @map("created_at")

  task        AgentTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, eventType])
  @@map("task_event_logs")
}


// -------------------------------------------
// Memory Layer
// -------------------------------------------

// Short-term memory is managed in Redis and is not part of the Prisma schema.
// This is a placeholder model for conceptual clarity if you were to store it in Postgres.
model ShortTermMemory {
  id          String        @id @default(uuid())
  sessionId   String
  memoryType  MemoryType    @map("memory_type")
  content     String
  tokenCount  Int           @map("token_count")
  createdAt   DateTime      @default(now()) @map("created_at")
  expiresAt   DateTime      @map("expires_at")
  
  session     AgentSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("short_term_memory")
}

enum MemoryType {
  CONTEXT
  SUMMARY
  HISTORY
}

// This relational table holds references to vectors stored in a Vector DB.
// Single source of truth: embeddings are stored in the external vector layer or pgvector-backed SQL migrations,
// while Prisma keeps only the reference identifier (`embeddingId`) plus metadata needed by the agent platform.
// This avoids Prisma pretending to own a pgvector column that may be provisioned separately during infra rollout.
model LongTermMemory {
  id            String        @id @default(uuid())
  userId        String
  workspaceId   String        @map("workspace_id")
  projectId     String?       @map("project_id")
  sourceType    SourceType    @map("source_type")
  sourceId      String        @map("source_id") // e.g., note_id, task_id
  chunkIndex    Int?          @map("chunk_index")
  tokenCount    Int?          @map("token_count")
  embeddingModel String?      @map("embedding_model")
  embeddingId   String        @unique @map("embedding_id") // ID in Pinecone/Weaviate
  summary       String?
  createdAt     DateTime      @default(now()) @map("created_at")
  deletedAt     DateTime?     @map("deleted_at")

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskLinks     LongTermMemoryLink[]

  @@index([userId, workspaceId])
  @@index([workspaceId, sourceType, sourceId])
  @@index([workspaceId, createdAt(sort: Desc)])
  @@map("long_term_memory")
}

enum SourceType {
  MESSAGE     @map("message")
  NOTE        @map("note")
  FILE_CHUNK  @map("file_chunk")
  KB_DOC      @map("kb_doc")
}

// Many-to-many link between Agent Tasks and Long-Term Memories
model LongTermMemoryLink {
  taskId    String
  memoryId  String

  task      AgentTask       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  memory    LongTermMemory  @relation(fields: [memoryId], references: [id], onDelete: Cascade)

  @@id([taskId, memoryId])
  @@map("long_term_memory_links")
}

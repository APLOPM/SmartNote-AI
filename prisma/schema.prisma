generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum SessionMode {
  QUICK
  DEEP
  AUTONOMOUS
}

enum SessionStatus {
  ACTIVE
  CLOSED
}

enum TaskStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum StepStatus {
  PENDING
  SUCCESS
  FAILED
  SKIPPED
}

enum ConversationRole {
  USER
  ASSISTANT
  SYSTEM
}

enum MemorySourceType {
  NOTE
  TASK
  CONVERSATION
}

//////////////////////////////////////////////////////
// USER
//////////////////////////////////////////////////////

model User {
  id              String         @id @default(uuid())
  email           String         @unique
  planType        String         @default("free")
  createdAt       DateTime       @default(now())

  sessions        AgentSession[]
  longTermMemory  LongTermMemory[]

  @@index([planType])
}

//////////////////////////////////////////////////////
// AGENT SESSION
//////////////////////////////////////////////////////

model AgentSession {
  id              String         @id @default(uuid())
  userId          String
  mode            SessionMode
  status          SessionStatus  @default(ACTIVE)
  startedAt       DateTime       @default(now())
  expiresAt       DateTime?

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  tasks           AgentTask[]
  memories        ShortTermMemory[]
  messages        ConversationMessage[]

  @@index([userId])
  @@index([status])
}

//////////////////////////////////////////////////////
// AGENT TASK
//////////////////////////////////////////////////////

model AgentTask {
  id                  String        @id @default(uuid())
  sessionId           String
  goal                String
  status              TaskStatus    @default(PENDING)
  currentStepIndex    Int           @default(0)
  totalSteps          Int?
  modelUsed           String?
  costEstimate        Decimal?      @db.Decimal(10, 4)
  tokenUsage          Int?
  createdAt           DateTime      @default(now())
  completedAt         DateTime?

  session             AgentSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  steps               TaskStep[]
  toolExecutions      ToolExecution[]
  eventLogs           TaskEventLog[]
  snapshots           TaskSnapshot[]
  memoryLinks         LongTermMemoryLink[]

  @@index([sessionId])
  @@index([status])
  @@index([createdAt])
}

//////////////////////////////////////////////////////
// TASK STEP
//////////////////////////////////////////////////////

model TaskStep {
  id              String      @id @default(uuid())
  taskId          String
  stepIndex       Int
  actionName      String
  inputPayload    Json?
  outputPayload   Json?
  status          StepStatus  @default(PENDING)
  startedAt       DateTime?
  finishedAt      DateTime?

  task            AgentTask   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  toolExecutions  ToolExecution[]

  @@unique([taskId, stepIndex])
  @@index([taskId])
}

//////////////////////////////////////////////////////
// TOOL EXECUTION
//////////////////////////////////////////////////////

model ToolExecution {
  id            String     @id @default(uuid())
  taskId        String
  stepId        String?
  toolName      String
  parameters    Json?
  result        Json?
  success       Boolean    @default(true)
  latencyMs     Int?
  retryCount    Int        @default(0)
  cost          Decimal?   @db.Decimal(10, 4)
  createdAt     DateTime   @default(now())

  task          AgentTask  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  step          TaskStep?  @relation(fields: [stepId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([toolName])
}

//////////////////////////////////////////////////////
// TASK SNAPSHOT (Resume Support)
//////////////////////////////////////////////////////

model TaskSnapshot {
  id            String      @id @default(uuid())
  taskId        String
  snapshotData  Json
  createdAt     DateTime    @default(now())

  task          AgentTask   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

//////////////////////////////////////////////////////
// TASK EVENT LOG (Audit)
//////////////////////////////////////////////////////

model TaskEventLog {
  id          String      @id @default(uuid())
  taskId      String
  eventType   String
  metadata    Json?
  createdAt   DateTime    @default(now())

  task        AgentTask   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([eventType])
}

//////////////////////////////////////////////////////
// SHORT TERM MEMORY
// This table serves as a persistent log or fallback for short-term memories,
// which are primarily managed in Redis.
//////////////////////////////////////////////////////

model ShortTermMemory {
  id            String        @id @default(uuid())
  sessionId     String
  memoryType    String
  content       String
  tokenCount    Int?
  createdAt     DateTime      @default(now())
  expiresAt     DateTime?

  session       AgentSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([expiresAt])
}

//////////////////////////////////////////////////////
// LONG TERM MEMORY (Vector reference)
//////////////////////////////////////////////////////

model LongTermMemory {
  id            String              @id @default(uuid())
  userId        String
  sourceType    MemorySourceType
  sourceId      String
  embeddingId   String              @unique
  summary       String?
  createdAt     DateTime            @default(now())

  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskLinks     LongTermMemoryLink[]

  @@index([userId])
  @@index([sourceType])
}

//////////////////////////////////////////////////////
// TASK <-> LONG TERM MEMORY LINK
//////////////////////////////////////////////////////

model LongTermMemoryLink {
  taskId     String
  memoryId   String

  task       AgentTask       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  memory     LongTermMemory  @relation(fields: [memoryId], references: [id], onDelete: Cascade)

  @@id([taskId, memoryId])
}

//////////////////////////////////////////////////////
// CONVERSATION MESSAGE
//////////////////////////////////////////////////////

model ConversationMessage {
  id          String            @id @default(uuid())
  sessionId   String
  role        ConversationRole
  content     String
  tokenCount  Int?
  createdAt   DateTime          @default(now())

  session     AgentSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

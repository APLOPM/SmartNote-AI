generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  users     User[]
  threads   Thread[]
  memories  Memory[]
}

model User {
  id        String   @id @default(uuid())
  tenantId  String
  email     String   @unique
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model Thread {
  id        String   @id @default(uuid())
  tenantId  String
  summary   String?
  createdAt DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  memories Memory[]
}

model Memory {
  id        String   @id @default(uuid())
  tenantId  String
  threadId  String
  role      String
  content   String
  embedding Bytes?   // pgvector stored via raw SQL
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  thread Thread @relation(fields: [threadId], references: [id])

  @@index([tenantId])
  @@index([threadId])
}

model Outbox {
  id        String   @id @default(uuid())
  topic     String
  key       String
  payload   Json
  published Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([published])
}

model QueryRequest {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  query     String
  createdAt DateTime @default(now())

  @@index([tenantId])
}

model QueryResponse {
  id        String   @id @default(uuid())
  requestId String   @unique
  response  String
  createdAt DateTime @default(now())
}

enum TaskStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum StepStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

enum MemorySourceType {
  NOTE
  TASK
  THREAD
}

model AgentTask {
  id           String      @id @default(uuid())
  sessionId    String
  goal         String
  status       TaskStatus  @default(PENDING)
  totalCostUsd Decimal     @default(0) @db.Decimal(10, 4)
  createdAt    DateTime    @default(now())
  completedAt  DateTime?

  steps        TaskStep[]
  executions   ToolExecution[]
  memoryLinks  LongTermMemoryLink[]

  @@index([sessionId])
  @@index([status])
}

model TaskStep {
  id           String      @id @default(uuid())
  taskId        String
  stepIndex     Int
  actionName    String
  inputPayload  Json
  outputPayload Json?
  status        StepStatus @default(PENDING)
  errorMessage  String?
  startedAt     DateTime?
  finishedAt    DateTime?
  createdAt     DateTime   @default(now())

  task        AgentTask        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  executions  ToolExecution[]

  @@unique([taskId, stepIndex])
  @@index([taskId, status])
}

model ToolExecution {
  id           String    @id @default(uuid())
  taskId        String
  stepId        String
  toolName      String
  parameters    Json
  result        Json
  success       Boolean
  errorMessage  String?
  latencyMs     Int
  costUsd       Decimal   @default(0) @db.Decimal(10, 4)
  createdAt     DateTime  @default(now())

  task  AgentTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  step  TaskStep  @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([stepId])
  @@index([toolName])
}

model LongTermMemory {
  id          String           @id @default(uuid())
  userId      String
  sourceType  MemorySourceType
  sourceId    String
  embeddingId String
  summary     String
  createdAt   DateTime         @default(now())

  links      LongTermMemoryLink[]

  @@index([userId])
  @@index([sourceType, sourceId])
}

model LongTermMemoryLink {
  id        String   @id @default(uuid())
  taskId     String
  memoryId   String
  createdAt  DateTime @default(now())

  task    AgentTask      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  memory  LongTermMemory @relation(fields: [memoryId], references: [id], onDelete: Cascade)

  @@unique([taskId, memoryId])
  @@index([memoryId])
}
